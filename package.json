{
  "name": "opencode-claude-max-proxy",
  "version": "1.17.0",
  "description": "Use your Claude Max subscription with OpenCode via proxy server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "claude-max-proxy": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "bun --watch run bin/cli.ts",
    "build": "bun scripts/build.ts",
    "start": "node ./dist/cli.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist && rm -rf node_modules"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.80",
    "@hono/node-server": "^1.19.11",
    "consola": "^3.4.2",
    "hono": "^4.11.4",
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.0.0",
    "dts-bundle-generator": "^9.5.1",
    "typescript": "^5.8.2"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "opencode-ai",
    "opencode-plugin",
    "claude",
    "claude-max",
    "claude-code",
    "anthropic",
    "ai-coding",
    "ai-assistant",
    "proxy",
    "claude-agent-sdk",
    "llm",
    "coding-assistant"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rynfar/opencode-claude-max-proxy.git"
  },
  "homepage": "https://github.com/rynfar/opencode-claude-max-proxy#readme",
  "bugs": {
    "url": "https://github.com/rynfar/opencode-claude-max-proxy/issues"
  },
  "author": "rynfar",
  "license": "MIT",
  "private": false,
  "packageManager": "bun@1.3.11"
}
